{
    "name": "payroll-automation-backend",
    "version": "1.0.0",
    "description": "Production-grade Salary Payout Automation with RazorpayX Integration",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "jest",
        "test:coverage": "jest --coverage",
        "test:integration": "jest --config=jest.integration.config.js",
        "lint": "eslint src/**/*.ts",
        "format": "prettier --write \"src/**/*.ts\"",
        "migrate": "ts-node src/scripts/migrate.ts"
    },
    "keywords": [
        "payroll",
        "razorpay",
        "automation",
        "hr",
        "salary",
        "payout"
    ],
    "author": "Your Company",
    "license": "MIT",
    "dependencies": {
        "express": "^4.18.2",
        "mongoose": "^7.0.0",
        "redis": "^4.6.0",
        "bull": "^4.11.0",
        "razorpay": "^2.8.1",
        "jsonwebtoken": "^9.0.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "helmet": "^7.0.0",
        "express-rate-limit": "^6.7.0",
        "dotenv": "^16.0.3",
        "nodemailer": "^6.9.0",
        "pdfkit": "^0.13.0",
        "winston": "^3.8.0",
        "joi": "^17.9.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.17",
        "@types/node": "^18.15.0",
        "@types/jest": "^29.5.0",
        "typescript": "^5.0.0",
        "ts-node": "^10.9.0",
        "jest": "^29.5.0",
        "ts-jest": "^29.1.0",
        "eslint": "^8.37.0",
        "@typescript-eslint/eslint-plugin": "^5.59.0",
        "@typescript-eslint/parser": "^5.59.0",
        "prettier": "^2.8.0",
        "nodemon": "^2.0.20"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    }
}